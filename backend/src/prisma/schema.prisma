// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "fullTextIndex"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================
// USERS & AUTH
// ============================================

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  fullName     String?
  phone        String?
  isAdmin      Boolean  @default(false)
  isManager    Boolean  @default(false)
  isActive     Boolean  @default(true)
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orders          Order[]
  addresses       Address[]
  refreshTokens   RefreshToken[]
  resetTokens     PasswordResetToken[]
  sentMessages    Message[]
  notifications   Notification[]
  statusChanges   OrderStatusLog[] @relation("StatusChanger")
  managedOrders   Order[]          @relation("OrderManager")

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("password_reset_tokens")
}

model Address {
  id         String   @id @default(uuid())
  userId     String
  label      String
  street     String
  city       String
  region     String
  postalCode String
  lat        Float?
  lng        Float?
  createdAt  DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@index([userId])
  @@map("addresses")
}

// ============================================
// PRODUCTS & CATEGORIES
// ============================================

model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?  @db.Text
  imageUrl    String?
  parentId    String?  @db.VarChar(191)
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent   Category?  @relation("ParentChild", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("ParentChild")
  products ProductCategory[]

  @@index([parentId])
  @@index([slug])
  @@map("categories")
}

model Product {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String   @db.Text
  priceCents  Int      // Price in cents (e.g., 250000 = 2500 XAF)
  stock       Int      @default(0)
  isActive    Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  images     ProductImage[]
  orderItems OrderItem[]
  categories ProductCategory[]

  @@index([slug])
  @@index([isActive])
  @@index([isFeatured])
  @@index([isActive, isFeatured])
  @@fulltext([name, description])
  @@map("products")
}

model ProductImage {
  id        String @id @default(uuid())
  productId String
  url       String
  publicId  String? // Cloudinary public_id for deletion
  altText   String @default("")
  position  Int    @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

model ProductCategory {
  productId  String
  categoryId String

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@map("product_categories")
}

// ============================================
// ORDERS & PAYMENTS
// ============================================

model Order {
  id               String   @id @default(uuid())
  orderNumber      String   @unique
  userId           String?
  managerId        String?
  status           String   @default("pending") // pending, preparing, delivering, delivered, cancelled
  fulfillment      String   // delivery, pickup
  addressId        String?
  subtotalCents    Int
  deliveryFeeCents Int      @default(0)
  taxCents         Int
  totalCents       Int
  paymentStatus    String   @default("pending") // pending, successful, failed
  paymentMethod    String?  // orange_money, mtn_momo, cash_on_delivery
  paymentPhone     String?
  notes            String?
  estimatedReadyAt DateTime?
  deliveredAt      DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user         User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  manager      User?            @relation("OrderManager", fields: [managerId], references: [id], onDelete: SetNull)
  address      Address?         @relation(fields: [addressId], references: [id], onDelete: SetNull)
  items        OrderItem[]
  payments     Payment[]
  messages     Message[]
  deliveryCode DeliveryCode?
  statusLogs   OrderStatusLog[]

  @@index([userId])
  @@index([managerId])
  @@index([status])
  @@index([orderNumber])
  @@index([addressId])
  @@index([paymentStatus])
  @@index([createdAt])
  @@index([status, paymentStatus])
  @@index([userId, createdAt])
  @@map("orders")
}

model OrderItem {
  id              String @id @default(uuid())
  orderId         String
  productId       String
  productSnapshot Json   // Snapshot of product data at time of order
  quantity        Int
  unitPriceCents  Int
  totalCents      Int

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model Payment {
  id                String   @id @default(uuid())
  orderId           String
  provider          String   // orange_money, mtn_momo, cash_on_delivery, flutterwave, cinetpay
  providerPaymentId String?
  externalRef       String?  // provider's transaction reference
  idempotencyKey    String   @unique // prevent duplicate payments
  amountCents       Int
  currency          String   @default("XAF")
  status            String   @default("initiated") // initiated, pending, processing, successful, failed, cancelled
  paymentPhone      String?  // customer's mobile money phone
  failureReason     String?
  attempts          Int      @default(1)
  metadata          Json     @default("{}")
  webhookVerified   Boolean  @default(false) // was this confirmed by a verified webhook?
  completedAt       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([providerPaymentId])
  @@index([idempotencyKey])
  @@index([status])
  @@index([createdAt])
  @@map("payments")
}

// ============================================
// FRAUD & AUDIT
// ============================================

model PaymentAttempt {
  id            String   @id @default(uuid())
  orderId       String
  userId        String?
  provider      String
  amountCents   Int
  phone         String?
  ipAddress     String?
  userAgent     String?
  status        String   // initiated, success, failed, blocked
  failureReason String?
  createdAt     DateTime @default(now())

  @@index([orderId])
  @@index([userId])
  @@index([ipAddress])
  @@index([createdAt])
  @@map("payment_attempts")
}

model FraudLog {
  id          String   @id @default(uuid())
  userId      String?
  orderId     String?
  action      String   // price_mismatch, duplicate_payment, invalid_webhook, rate_exceeded, suspicious_activity
  details     Json     @default("{}")
  ipAddress   String?
  severity    String   @default("medium") // low, medium, high, critical
  resolved    Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([orderId])
  @@index([severity])
  @@index([createdAt])
  @@map("fraud_logs")
}

// ============================================
// CHAT & NOTIFICATIONS
// ============================================

model Message {
  id        String   @id @default(uuid())
  orderId   String
  senderId  String
  content   String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  order  Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sender User  @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([senderId])
  @@index([createdAt])
  @@map("messages")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String   // order_created, order_validated, order_status_change, new_message
  title     String
  body      String   @db.Text
  channel   String   // email, sms, whatsapp, in_app
  status    String   @default("pending") // pending, sent, failed
  metadata  Json     @default("{}")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([isRead])
  @@map("notifications")
}

// ============================================
// DELIVERY & ORDER TRACKING
// ============================================

model DeliveryCode {
  id        String   @id @default(uuid())
  orderId   String   @unique
  codeHash  String
  code      String?  @db.VarChar(6)
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  usedAt    DateTime?
  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("delivery_codes")
}

model OrderStatusLog {
  id        String   @id @default(uuid())
  orderId   String
  fromStatus String?
  toStatus  String
  changedBy String?
  note      String?  @db.Text
  createdAt DateTime @default(now())

  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  changer User? @relation("StatusChanger", fields: [changedBy], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([createdAt])
  @@map("order_status_logs")
}

// ============================================
// AUDIT
// ============================================

model AuditLog {
  id        String   @id @default(uuid())
  actorId   String?
  action    String
  resource  String?
  resourceId String?
  details   Json     @default("{}")
  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([createdAt])
  @@index([resource])
  @@map("audit_logs")
}
