{
  "name": "patisserie-backend",
  "version": "1.0.0",
  "description": "Backend API for Patisserie e-commerce platform",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:prod": "prisma migrate deploy",
    "prisma:seed": "ts-node src/prisma/seed.ts",
    "prisma:studio": "prisma studio"
  },
  "keywords": [
    "api",
    "express",
    "prisma",
    "postgresql"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.7.1",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "dotenv": "^16.3.1",
    "class-validator": "^0.14.0",
    "class-transformer": "^0.5.1",
    "express-rate-limit": "^7.1.5",
    "uuid": "^9.0.1",
    "morgan": "^1.10.0",
    "axios": "^1.6.5",
    "socket.io": "^4.7.4",
    "cloudinary": "^2.0.1",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.8",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/jest": "^29.5.11",
    "@types/morgan": "^1.9.9",
    "@types/uuid": "^9.0.7",
    "@types/cors": "^2.8.17",
    "@types/multer": "^1.4.11",
    "@types/nodemailer": "^6.4.14",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "prisma": "^5.7.1"
  }
}