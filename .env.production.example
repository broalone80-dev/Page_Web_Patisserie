# ============================================
# PRODUCTION ENVIRONMENT — Chez GuiGui
# ============================================
# IMPORTANT: Generate strong secrets before deployment!
# Run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

# ─── Database (MySQL) ───
DATABASE_URL=mysql://patisserie_user:CHANGE_ME_STRONG_PASSWORD@db:3306/patisserie_db

# ─── JWT ───
JWT_SECRET=CHANGE_ME_GENERATE_64_BYTE_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_ANOTHER_64_BYTE_SECRET
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ─── Server ───
NODE_ENV=production
PORT=4000
API_BASE_URL=https://api.chezguigui.cm
FRONTEND_URL=https://chezguigui.cm

# ─── CORS ───
CORS_ORIGIN=https://chezguigui.cm

# ─── Payment Security ───
PAYMENT_WEBHOOK_SECRET=CHANGE_ME_WEBHOOK_SECRET

# ─── Orange Money Cameroun ───
ORANGE_MONEY_API_URL=https://api.orange.com/orange-money-webpay/cm/v1
ORANGE_MONEY_API_KEY=
ORANGE_MONEY_CLIENT_ID=
ORANGE_MONEY_CLIENT_SECRET=
ORANGE_MONEY_MERCHANT_KEY=

# ─── MTN MoMo Cameroun ───
MTN_MOMO_API_URL=https://proxy.momoapi.mtn.com
MTN_MOMO_API_KEY=
MTN_MOMO_API_USER_ID=
MTN_MOMO_SUBSCRIPTION_KEY=
MTN_MOMO_ENVIRONMENT=production

# ─── Cloudinary (images) ───
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Email (SMTP) ───
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@chezguigui.cm

# ─── Docker ───
DB_USER=patisserie_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD
DB_NAME=patisserie_db
DOCKER_USERNAME=broalone80

# ─── Sentry (error tracking, optional) ───
SENTRY_DSN=
